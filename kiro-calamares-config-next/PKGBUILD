# Maintainer: Erik Dubois <erik.dubois@gmail.com>
pkgname=kiro-calamares-config-next
_pkgname=kiro-calamares-config-next
_destname1="/etc"
_destname2="/usr"
pkgver=26.06
pkgrel=03
pkgdesc="calamares config for kiro"
arch=('any')
url="https://github.com/kirodubes/${_pkgname}"
license=('GPL3')
makedepends=('git')
depends=()
conflicts=(kiro-calamares-config)
provides=("${pkgname}")
options=(!strip !emptydirs)
source=(${_pkgname}::"git+$url")
sha256sums=('SKIP')
install='readme.install'
package() {
	mkdir -p "${pkgdir}${_destname1}"
	cp -r "${srcdir}/${_pkgname}/${_destname1}"* "${pkgdir}"
	mkdir -p "${pkgdir}${_destname2}"
	cp -r "${srcdir}/${_pkgname}/${_destname2}"* "${pkgdir}"
}
