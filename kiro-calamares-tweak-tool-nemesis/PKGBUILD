# Maintainer: Erik Dubois <erik.dubois@gmail.com>
pkgname=kiro-calamares-tweak-tool-nemesis
_pkgname=kiro-calamares-tweak-tool-nemesis
_destname1="/usr"
_licensedir="/usr/share/kiro/licenses/"
pkgver=26.06
pkgrel=16
pkgdesc="Dev/expert tool to set Calamares encryption + bootloader before installing (PySide6/QML)"
arch=('any')
url="https://github.com/kirodubes/${_pkgname}"
license=('GPL3')
makedepends=('git')
depends=('pyside6' 'polkit')
optdepends=('libnotify: desktop notification when settings are applied')
provides=("${pkgname}")
options=(!strip !emptydirs)
source=(${_pkgname}::"git+$url")
sha256sums=('SKIP')
package() {
	install -dm755 "${pkgdir}${_licensedir}${_pkgname}"
	install -m644 "${srcdir}/${_pkgname}/LICENSE" "${pkgdir}${_licensedir}${_pkgname}/LICENSE"
	cp -r "${srcdir}/${_pkgname}/${_destname1}" "${pkgdir}"
}
